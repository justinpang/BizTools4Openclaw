# ============================================================
# BizTools4Openclaw —— 开发环境配置
# ============================================================
# 复制此文件后重命名为 .env（不要提交真实密钥到版本控制）

# ---------- 基础环境 ----------
ENV=dev
DEBUG=true
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# ---------- Python 版本声明（文档化，不影响运行）----------
# 本项目使用 Python 3.11
# - 本地开发：py -3.11  或  激活 Python 3.11 虚拟环境
# - Docker 构建：使用 python:3.11-slim 基础镜像

# ---------- 数据库 ----------
# 方案 A（推荐本地开发）：SQLite 模式，无需任何外部数据库
DB_BACKEND=sqlite
DB_SQLITE_PATH=

# 方案 B（生产/集成测试）：PostgreSQL（需要 Docker 启动 db 服务）
# DB_BACKEND=postgres
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=biztools
# DB_USER=postgres
# DB_PASSWORD=change-me

# 数据库连接池（仅 PostgreSQL 模式下生效）
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ---------- 加密密钥（必填，至少 32 字符）----------
DB_ENCRYPTION_KEY=please-change-this-to-a-strong-random-32-chars!!

# ---------- Redis ----------
# 本地开发：如未安装 Redis，将自动降级为内存 stub
QUEUE_REDIS_HOST=127.0.0.1
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_DB=0

# ---------- 应用服务 ----------
ADAPTER_HOST=0.0.0.0
ADAPTER_PORT=8000
ADAPTER_BASE_URL=http://localhost:8000

# ---------- Web 管理后台 ----------
WEB_ADMIN_ENABLED=true
WEB_ADMIN_HOST=0.0.0.0
WEB_ADMIN_PORT=8080
WEB_ADMIN_SECRET_KEY=change-me-web-admin-secret

# ---------- 代理（可选，用于爬虫模块）----------
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
