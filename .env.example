# ========== 项目基础配置 ==========
PROJECT_NAME=openclaw-business-tools
ENV=dev
DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api/v1

# ========== 密钥 ==========
SECRET_KEY=change-me-please-generate-a-random-key-here
API_TOKEN=change-me-api-token-for-internal-calls

# ========== 数据库（PostgreSQL + pgvector） ==========
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-postgres-password
DB_NAME=openclaw_biz
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
# 敏感字段加密主密钥（AES-256，至少 16 字符，推荐 32+ 字符）
DB_ENCRYPTION_KEY=please-change-this-to-a-strong-random-key
# 数据冷热分离/归档阈值（天），默认 90 天
DB_ARCHIVE_DAYS=90
# 高价值商机保留阈值（金额单位与业务一致，如美元）
DB_ARCHIVE_HOT_THRESHOLD=1000
# 对外接口查询时是否二次脱敏显示（true/false）
DB_SENSITIVE_MASK_ENABLED=true

# ========== Redis ==========
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=openclaw_biz

# ========== OpenClaw 网关 ==========
OPENCLAW_GATEWAY_URL=https://gateway.openclaw.example.com
OPENCLAW_GATEWAY_TOKEN=change-me-openclaw-token
OPENCLAW_CALLBACK_URL=http://127.0.0.1:8000/api/v1/callback

# ========== 爬虫代理 ==========
PROXY_ENABLED=false
PROXY_HTTP=http://user:pass@proxy.example.com:8080
PROXY_HTTPS=http://user:pass@proxy.example.com:8080
CRAWLER_UA=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0 Safari/537.36
CRAWLER_RATE_LIMIT=10

# ========== 消息渠道 ==========
# 微信
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TEMPLATE_ID=
# 飞书
FEISHU_WEBHOOK_URL=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 邮件（告警用，多收件人逗号分隔）
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_TO=

# ========== 告警 ==========
ALERT_ENABLED=false
# 钉钉机器人
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=
# 三类告警场景开关
ALERT_TASK_FAILURE_ENABLED=true
ALERT_SERVICE_EXCEPTION_ENABLED=true
ALERT_CRAWLER_RISK_ENABLED=true

# ========== 日志 ==========
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_ROTATION=1 day
LOG_RETENTION=30 days
LOG_CONSOLE_ENABLED=true
LOG_FILE_ENABLED=true

# ========== 任务调度 ==========
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Shanghai
SCHEDULER_MAX_CONCURRENT=10
SCHEDULER_MISFIRE_GRACE_TIME=60
SCHEDULER_COALESCE=true
SCHEDULER_JOBSTORES_REDIS=false
SCHEDULER_STORE_PREFIX=openclaw:scheduler

# ========== 异步任务队列 ==========
QUEUE_REDIS_HOST=127.0.0.1
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=
QUEUE_REDIS_DB=1
QUEUE_PREFIX=openclaw:queue
QUEUE_NAME=default
QUEUE_POOL_SIZE=10
QUEUE_POOL_TIMEOUT=30
QUEUE_TASK_TIMEOUT=300
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_BACKOFF=2
QUEUE_WORKER_CONCURRENCY=4
QUEUE_BPOP_TIMEOUT=5
QUEUE_TASK_TTL=604800
